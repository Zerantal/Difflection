<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Button.sidebarIconButton">
        <Setter Property="Background" Value="#262626" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.sidebarIconButton:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.headerIconButton">
        <Setter Property="Background" Value="#262626" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.headerIconButton:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.imageActionIconButton">
        <Setter Property="Background" Value="#262626" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
    </Style>
    <Style Selector="Button.imageActionIconButton:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.imageActionIconButton.baselineActive">
        <Setter Property="Background" Value="#3A2A1F" />
        <Setter Property="BorderBrush" Value="#F97316" />
    </Style>
    <Style Selector="Button.imageActionIconButton.candidateActive">
        <Setter Property="Background" Value="#1F2C3A" />
        <Setter Property="BorderBrush" Value="#38BDF8" />
    </Style>
    <Style Selector="Button.viewModeButton">
        <Setter Property="Background" Value="#262626" />
        <Setter Property="Foreground" Value="#A8AFB8" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.viewModeButton:disabled">
        <Setter Property="Opacity" Value="0.58" />
    </Style>
    <Style Selector="ToggleButton.diffBaseToggle">
        <Setter Property="Background" Value="#181818" />
        <Setter Property="Foreground" Value="#A8AFB8" />
        <Setter Property="BorderBrush" Value="#3A3A3A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="ToggleButton.diffBaseToggle:checked">
        <Setter Property="Background" Value="#26313A" />
        <Setter Property="Foreground" Value="#D7E8F5" />
        <Setter Property="BorderBrush" Value="#5F7788" />
    </Style>
    <Style Selector="TextBlock.sidebarHeading">
        <Setter Property="Foreground" Value="#9AA1AB" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
    <Style Selector="ListBox.sidebarList">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ComboBox.projectSelector">
        <Setter Property="Background" Value="#101010" />
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="#3A3A3A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="8,7" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2A2A" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A2A1F" />
    </Style>
    <Style Selector="ListBox#ComparisonImagesList ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.comparisonRowReview">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.comparisonRowReview.needsReview">
        <Setter Property="Background" Value="#221F14" />
        <Setter Property="BorderBrush" Value="#A16207" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBlock.sidebarItemText">
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.sidebarItemDetailText">
        <Setter Property="Foreground" Value="#8C939D" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBox.nameEditor">
        <Setter Property="Background" Value="#101010" />
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="#3A3A3A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox.sidebarInlineName">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="TextBox.sidebarInlineName:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TextBox.sidebarInlineName.editing">
        <Setter Property="Background" Value="#101010" />
        <Setter Property="BorderBrush" Value="#525252" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="TextBox.inlineImageLabel">
        <Setter Property="Background" Value="#101010" />
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="#3A3A3A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Border.toolbarSeparator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="#3A3A3A" />
        <Setter Property="Margin" Value="2,0" />
    </Style>
    <Style Selector="TextBox.toolbarZoomBox">
        <Setter Property="Background" Value="#101010" />
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="#3A3A3A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Border.imageSetCard">
        <Setter Property="Background" Value="#121212" />
        <Setter Property="BorderBrush" Value="#383838" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Width" Value="238" />
        <Setter Property="MinHeight" Value="168" />
    </Style>
    <Style Selector="Grid.revisionTile">
        <Setter Property="Width" Value="96" />
        <Setter Property="Height" Value="70" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
    <Style Selector="Button.revisionThumbnailButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.revisionThumbnailFrame">
        <Setter Property="Background" Value="#0A0A0A" />
        <Setter Property="BorderBrush" Value="#343434" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.revisionThumbnailFrame.active.baseline">
        <Setter Property="BorderBrush" Value="#00AFFF" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Border.revisionThumbnailFrame.active.candidate">
        <Setter Property="BorderBrush" Value="#F97316" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Button.revisionDeleteButton">
        <Setter Property="Background" Value="#101010D8" />
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="#3A3A3A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
    </Style>
    <Style Selector="Border.revisionMetaOverlay">
        <Setter Property="Background" Value="#050505D8" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="CornerRadius" Value="0,4,0,0" />
    </Style>
    <Style Selector="Border.revisionTagOverlay">
        <Setter Property="Background" Value="#101010E8" />
        <Setter Property="BorderBrush" Value="#525252" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="CornerRadius" Value="0,0,4,0" />
        <Setter Property="MaxWidth" Value="78" />
    </Style>
    <Style Selector="TextBlock.revisionTagText">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.revisionMetaText">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.imageThumbnailFrame">
        <Setter Property="Background" Value="#0A0A0A" />
        <Setter Property="BorderBrush" Value="#282828" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Height" Value="86" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.roleBadge">
        <Setter Property="Background" Value="#2B2B2B" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="Border.baselineBadge">
        <Setter Property="Background" Value="#3A2A1F" />
        <Setter Property="BorderBrush" Value="#F97316" />
    </Style>
    <Style Selector="Border.candidateBadge">
        <Setter Property="Background" Value="#1F2C3A" />
        <Setter Property="BorderBrush" Value="#38BDF8" />
    </Style>
