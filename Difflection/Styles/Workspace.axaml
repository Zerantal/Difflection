    </Style>
    <Style Selector="TextBlock.imageSetTitleText">
        <Setter Property="Foreground" Value="#C3CBD5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.channelFrame">
        <Setter Property="Background" Value="#121212" />
        <Setter Property="BorderBrush" Value="#343434" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.baselineChannelFrame">
        <Setter Property="BorderBrush" Value="#245163" />
    </Style>
    <Style Selector="Border.candidateChannelFrame">
        <Setter Property="BorderBrush" Value="#65401F" />
    </Style>
    <Style Selector="Border.channelLabel">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="70" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.baselineChannelLabel">
        <Setter Property="Background" Value="#0C2530" />
        <Setter Property="BorderBrush" Value="#00AFFF" />
    </Style>
    <Style Selector="Border.candidateChannelLabel">
        <Setter Property="Background" Value="#302012" />
        <Setter Property="BorderBrush" Value="#F97316" />
    </Style>
    <Style Selector="TextBlock.channelLabelText">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Width" Value="70" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.workspaceContextTitle">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.workspaceContextDetail">
        <Setter Property="Foreground" Value="#9AA1AB" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.emptyStateTitle">
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.emptyStateMessage">
        <Setter Property="Foreground" Value="#9AA1AB" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.sidebarEmptyText">
        <Setter Property="Foreground" Value="#737B86" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="8,8,8,0" />
