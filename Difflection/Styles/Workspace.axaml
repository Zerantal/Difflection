<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Button.sidebarIconButton">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.sidebarIconButton:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.headerIconButton">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.headerIconButton:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.imageActionIconButton">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
    </Style>
    <Style Selector="Button.imageActionIconButton:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.imageActionIconButton.baselineActive">
        <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.imageActionIconButton.candidateActive">
        <Setter Property="Background" Value="{DynamicResource ActiveBlueSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ActiveBlueBrush}" />
    </Style>
    <Style Selector="Button.viewModeButton">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextInteractiveBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.viewModeButton:disabled">
        <Setter Property="Opacity" Value="0.58" />
    </Style>
    <Style Selector="ToggleButton.diffBaseToggle">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextInteractiveBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="ToggleButton.diffBaseToggle:checked">
        <Setter Property="Background" Value="{DynamicResource CheckedBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource CheckedForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CheckedBorderBrush}" />
    </Style>
    <Style Selector="TextBlock.sidebarHeading">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
    <Style Selector="ListBox.sidebarList">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ComboBox.projectSelector">
        <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="8,7" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
    </Style>
    <Style Selector="ListBox#ComparisonImagesList ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.comparisonRowReview">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.comparisonRowReview.needsReview">
        <Setter Property="Background" Value="{DynamicResource WarningSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBlock.sidebarItemText">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.sidebarItemDetailText">
        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBox.nameEditor">
        <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox.sidebarInlineName">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="TextBox.sidebarInlineName:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TextBox.sidebarInlineName.editing">
        <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="TextBox.inlineImageLabel">
        <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Border.toolbarSeparator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        <Setter Property="Margin" Value="2,0" />
    </Style>
    <Style Selector="TextBox.toolbarZoomBox">
        <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Border.imageSetCard">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Width" Value="238" />
        <Setter Property="MinHeight" Value="168" />
    </Style>
    <Style Selector="Grid.revisionTile">
        <Setter Property="Width" Value="96" />
        <Setter Property="Height" Value="70" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
    <Style Selector="Button.revisionThumbnailButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.revisionThumbnailFrame">
        <Setter Property="Background" Value="{DynamicResource ThumbnailBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RulerBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.revisionThumbnailFrame.active.baseline">
        <Setter Property="BorderBrush" Value="{DynamicResource BaselineBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Border.revisionThumbnailFrame.active.candidate">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Button.revisionDeleteButton">
        <Setter Property="Background" Value="{DynamicResource ControlOverlayBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
    </Style>
    <Style Selector="Border.revisionMetaOverlay">
        <Setter Property="Background" Value="{DynamicResource ThumbnailOverlayBrush}" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="CornerRadius" Value="0,4,0,0" />
    </Style>
    <Style Selector="Border.revisionTagOverlay">
        <Setter Property="Background" Value="{DynamicResource ThumbnailTagOverlayBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="CornerRadius" Value="0,0,4,0" />
        <Setter Property="MaxWidth" Value="78" />
    </Style>
    <Style Selector="TextBlock.revisionTagText">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.revisionMetaText">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.imageThumbnailFrame">
        <Setter Property="Background" Value="{DynamicResource ThumbnailBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderFaintBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Height" Value="86" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.roleBadge">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="Border.baselineBadge">
        <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.candidateBadge">
        <Setter Property="Background" Value="{DynamicResource ActiveBlueSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ActiveBlueBrush}" />
    </Style>
    <Style Selector="TextBlock.roleBadgeText">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.imageSourceText">
        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.imageVersionText">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.imageSetHeaderText">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="0.4" />
    </Style>
    <Style Selector="TextBlock.imageSetTitleText">
        <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.channelFrame">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RulerBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.baselineChannelFrame">
        <Setter Property="BorderBrush" Value="{DynamicResource BaselineBorderBrush}" />
    </Style>
    <Style Selector="Border.candidateChannelFrame">
        <Setter Property="BorderBrush" Value="{DynamicResource CandidateBorderBrush}" />
    </Style>
    <Style Selector="Border.channelLabel">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="70" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.baselineChannelLabel">
        <Setter Property="Background" Value="{DynamicResource BaselineSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BaselineBrush}" />
    </Style>
    <Style Selector="Border.candidateChannelLabel">
        <Setter Property="Background" Value="{DynamicResource CandidateSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CandidateBrush}" />
    </Style>
    <Style Selector="TextBlock.channelLabelText">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Width" Value="70" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.workspaceContextTitle">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.workspaceContextDetail">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.emptyStateTitle">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.emptyStateMessage">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.sidebarEmptyText">
        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="8,8,8,0" />
    </Style>
</Styles>
