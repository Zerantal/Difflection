    <UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="using:Difflection.Views"
             xmlns:vm="using:Difflection.ViewModels"
             x:Class="Difflection.Views.ComparisonStage"
             x:DataType="vm:MainWindowViewModel"
             d:DesignWidth="400"
             d:DesignHeight="200"
             Background="#1B1B1B">
        
        <Grid ClipToBounds="True"
          RowDefinitions="28,*"
          ColumnDefinitions="44,*"
          Background="#1B1B1B">
        <Border Grid.Row="1"
                Grid.Column="1"
                IsVisible="{Binding IsSideBySideView}"
                BorderBrush="#242424"
                BorderThickness="1"
                Background="#050505">
            <Grid x:Name="SideBySideSurface"
                  ClipToBounds="True"
                  ColumnDefinitions="*,16,*">
                <views:RuledImagePane x:Name="SideBySideLeftPane"
                                      Grid.Column="0"
                                      SurfaceWidth="{Binding LeftImageWidth}"
                                      SurfaceHeight="{Binding LeftImageHeight}"
                                      ImageSource="{Binding LeftImage}"
                                      ZoomScale="{Binding ZoomScale}" />

                <Border x:Name="SideBySideGutter"
                        Grid.Column="1"
                        Width="16"
                        Background="#101010"
                        IsVisible="{Binding HasBothImages}" />

                <views:RuledImagePane x:Name="SideBySideRightPane"
                                      Grid.Column="2"
                                      SurfaceWidth="{Binding RightImageWidth}"
                                      SurfaceHeight="{Binding RightImageHeight}"
                                      ImageSource="{Binding RightImage}"
                                      ZoomScale="{Binding ZoomScale}"
                                      IsVisible="{Binding HasBothImages}" />

                <Border x:Name="SideBySideDropOverlay"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        IsVisible="{Binding IsSideBySideView}"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="StageOverlay_OnDragOver"
                        DragDrop.Drop="StageOverlay_OnDrop" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                IsVisible="{Binding IsSplitScreenView}"
                BorderBrush="#242424"
                BorderThickness="1"
                Background="#050505">
            <Grid ClipToBounds="True">
                <views:RuledSplitImagePane x:Name="SplitPane"
                                           IsVisible="{Binding IsSplitScreenView}"
                                           ZoomScale="{Binding ZoomScale}"
                                           SurfaceWidth="{Binding StageWidth}"
                                           SurfaceHeight="{Binding StageHeight}"
                                           LeftImage="{Binding LeftImage}"
                                           RightImage="{Binding RightImage}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
