<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Difflection.ViewModels"
             xmlns:views="using:Difflection.Views"
             xmlns:fi="using:FluentIcons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Difflection.Views.MainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel"
             SizeChanged="MainView_OnSizeChanged"
             Background="#181818">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.toolbarPrimary">
            <Setter Property="Background" Value="#C2410C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#F97316" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.toolbarSecondary">
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.sidebarIconButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.sidebarIconButton:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.headerIconButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.headerIconButton:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.imageActionIconButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
        </Style>
        <Style Selector="Button.imageActionIconButton:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.viewModeButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#A8AFB8" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.viewModeButton:disabled">
            <Setter Property="Opacity" Value="0.58" />
        </Style>
        <Style Selector="TextBlock.sidebarHeading">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>
        <Style Selector="ListBox.sidebarList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ComboBox.projectSelector">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A2A1F" />
        </Style>
        <Style Selector="ListBox#ComparisonImagesList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBlock.sidebarItemText">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.sidebarItemDetailText">
            <Setter Property="Foreground" Value="#8C939D" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBox.nameEditor">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox.sidebarInlineName">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="TextBox.sidebarInlineName:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TextBox.sidebarInlineName.editing">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#525252" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
        <Style Selector="TextBox.inlineImageLabel">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.imageActionButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Border.toolbarSeparator">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Margin" Value="2,0" />
        </Style>
        <Style Selector="TextBox.toolbarZoomBox">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Border.imageSetCard">
            <Setter Property="Background" Value="#121212" />
            <Setter Property="BorderBrush" Value="#383838" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Width" Value="238" />
            <Setter Property="MinHeight" Value="168" />
        </Style>
        <Style Selector="Border.imageThumbnailFrame">
            <Setter Property="Background" Value="#0A0A0A" />
            <Setter Property="BorderBrush" Value="#282828" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Height" Value="86" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Border.roleBadge">
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <Style Selector="Border.referenceBadge">
            <Setter Property="Background" Value="#3A2A1F" />
            <Setter Property="BorderBrush" Value="#F97316" />
        </Style>
        <Style Selector="Border.candidateBadge">
            <Setter Property="Background" Value="#1F2C3A" />
            <Setter Property="BorderBrush" Value="#38BDF8" />
        </Style>
        <Style Selector="TextBlock.roleBadgeText">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.imageSourceText">
            <Setter Property="Foreground" Value="#8C939D" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.imageVersionText">
            <Setter Property="Foreground" Value="#F97316" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.imageSetHeaderText">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.4" />
        </Style>
        <Style Selector="TextBlock.imageCardTitle">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.workspaceContextTitle">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.workspaceContextDetail">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.emptyStateTitle">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.emptyStateMessage">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.sidebarEmptyText">
            <Setter Property="Foreground" Value="#737B86" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="8,8,8,0" />
        </Style>
    </UserControl.Styles>

    <Grid x:Name="RootGrid" RowDefinitions="34,60,*,Auto" ColumnDefinitions="260,5,*" Background="#181818">
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#222222" BorderBrush="#353535" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" Margin="14,0">
                <TextBlock Text="Difflection"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Static Image Diff"
                           FontSize="12"
                           Foreground="#8C939D"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#171717"
                BorderBrush="#303030"
                BorderThickness="0,0,1,1" />

        <Border Grid.Row="1" Grid.Column="2" Background="#202020" BorderBrush="#363636"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" Margin="12,0" DataContext="{Binding}">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <Button x:Name="SideBySideViewButton"
                            Classes="viewModeButton"
                            Content="Side-by-side"
                            Click="SideBySideViewButton_OnClick" />
                    <Button x:Name="SplitScreenViewButton"
                            Classes="viewModeButton"
                            Content="Split screen"
                            IsEnabled="{Binding ToolState.CanUseSplitScreen}"
                            Click="SplitScreenViewButton_OnClick" />
                    <Border Classes="toolbarSeparator" />
                    <Button Classes="headerIconButton"
                            ToolTip.Tip="Add images to comparison"
                            Click="AddMediaButton_OnClick">
                        <fi:FluentIcon Icon="Add"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                    <Button Classes="headerIconButton"
                            ToolTip.Tip="Refresh source images for selected comparison"
                            IsEnabled="{Binding Workspace.HasSelectedComparison}"
                            Click="RefreshSelectedComparisonSourcesButton_OnClick">
                        <fi:FluentIcon Icon="ImageArrowCounterclockwise"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <TextBlock Text="{Binding ToolState.SplitPercentageText}"
                               IsVisible="{Binding ToolState.IsSplitScreenView}"
                               Foreground="#BFC4CC"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="ZoomTextBox"
                             Classes="toolbarZoomBox"
                             Width="64"
                             ToolTip.Tip="Zoom percentage"
                             Text="{Binding ToolState.ZoomText, Mode=TwoWay}"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Center"
                             LostFocus="ZoomTextBox_OnLostFocus"
                             KeyDown="ZoomTextBox_OnKeyDown" />
                    <Button Classes="headerIconButton"
                            ToolTip.Tip="Fit images to stage"
                            IsEnabled="{Binding ComparisonDisplay.HasAnyImage}"
                            Click="FitZoomButton_OnClick">
                        <fi:FluentIcon Icon="AutoFitWidth"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                    <Button Classes="headerIconButton"
                            ToolTip.Tip="Actual size"
                            IsEnabled="{Binding ComparisonDisplay.HasAnyImage}"
                            Click="ActualSizeZoomButton_OnClick">
                        <fi:FluentIcon Icon="FullScreenMaximize"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                    <Button Classes="headerIconButton"
                            ToolTip.Tip="Settings">
                        <fi:FluentIcon Icon="AppsSettings"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.RowSpan="3"
                      Grid.Column="1"
                      Background="#3A3A3A"
                      BorderBrush="#4A4A4A"
                      BorderThickness="1,0"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <Border Grid.Row="2"
                Grid.RowSpan="2"
                Grid.Column="0"
                Background="#171717"
                BorderBrush="#303030"
                BorderThickness="0,0,1,0"
                Padding="12"
                DataContext="{Binding Workspace}">
            <Grid RowDefinitions="Auto,Auto,16,Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBlock Classes="sidebarHeading"
                               Text="PROJECT"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddProjectButton"
                            Grid.Column="1"
                            Classes="sidebarIconButton"
                            ToolTip.Tip="Add project"
                            Command="{Binding AddProjectForInlineRenameCommand}">
                        <fi:FluentIcon Icon="Add"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                </Grid>

                <ComboBox x:Name="ProjectsSelector"
                          Grid.Row="1"
                          Classes="projectSelector"
                          ItemsSource="{Binding ProjectRows}"
                          SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                          IsEnabled="{Binding HasProjects}"
                          IsVisible="{Binding HasProjects}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectListItemViewModel">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Classes="sidebarItemDetailText"
                                           Text="{Binding DetailText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Grid.Row="1"
                           Classes="sidebarEmptyText"
                           Text="No projects yet."
                           IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).WorkspaceStatus.ShowProjectsEmptyState}" />

                <Border Grid.Row="2" Height="1" Background="#303030" VerticalAlignment="Center" />

                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBlock Classes="sidebarHeading"
                               Text="COMPARISONS"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddComparisonButton"
                            Grid.Column="1"
                            Classes="sidebarIconButton"
                            ToolTip.Tip="Add comparison"
                            IsEnabled="{Binding CanAddComparison}"
                            Command="{Binding AddComparisonForInlineRenameCommand}">
                        <fi:FluentIcon Icon="Add"
                                       IconVariant="Regular"
                                       IconSize="Size16" />
                    </Button>
                </Grid>

                <ListBox x:Name="ComparisonsList"
                         Grid.Row="4"
                         Classes="sidebarList"
                         ItemsSource="{Binding SelectedProjectComparisonRows}"
                         SelectedItem="{Binding SelectedComparisonRow, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ComparisonListItemViewModel">
                            <Border Background="{Binding ReviewBackground}"
                                    BorderBrush="{Binding ReviewBorderBrush}"
                                    BorderThickness="{Binding ReviewBorderThickness}"
                                    CornerRadius="4"
                                    Padding="6,4"
                                    ContextRequested="SidebarItem_OnContextRequested">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Refresh source images"
                                                  Click="RefreshComparisonSourcesMenuItem_OnClick" />
                                        <MenuItem Header="Rename" />
                                        <MenuItem Header="Delete"
                                                  Click="DeleteComparisonMenuItem_OnClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <TextBlock Classes="sidebarItemText"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsNotEditing}" />
                                    <TextBox Classes="sidebarInlineName editing"
                                             Text="{Binding DraftName, Mode=TwoWay}"
                                             IsVisible="{Binding IsEditing}"
                                             AttachedToVisualTree="InlineNameTextBox_OnAttachedToVisualTree"
                                             PropertyChanged="InlineNameTextBox_OnPropertyChanged"
                                             LostFocus="ComparisonListNameTextBox_OnLostFocus"
                                             KeyDown="ComparisonListNameTextBox_OnKeyDown" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="4"
                           Classes="sidebarEmptyText"
                           Text="No comparisons in this project."
                           IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).WorkspaceStatus.ShowComparisonsEmptyState}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="2" Background="#101010" Padding="24">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*" ColumnSpacing="12">
                    <StackPanel Spacing="6"
                                VerticalAlignment="Center"
                                DataContext="{Binding Workspace}">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                            <TextBlock Classes="workspaceContextTitle"
                                       Text="{Binding SelectedProjectName}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding SelectedProjectRow.IsNotEditing}" />
                            <TextBlock Classes="workspaceContextTitle"
                                       Text="No project selected"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ShowProjectsEmptyState}" />
                            <TextBox x:Name="ProjectNameTextBox"
                                     Classes="nameEditor"
                                     MinWidth="260"
                                     DataContext="{Binding SelectedProjectRow}"
                                     Text="{Binding DraftName, Mode=TwoWay}"
                                     IsVisible="{Binding IsEditing}"
                                     AttachedToVisualTree="InlineNameTextBox_OnAttachedToVisualTree"
                                     PropertyChanged="InlineNameTextBox_OnPropertyChanged"
                                     LostFocus="ProjectListNameTextBox_OnLostFocus"
                                     KeyDown="ProjectListNameTextBox_OnKeyDown" />
                            <Button x:Name="EditProjectButton"
                                    Grid.Column="1"
                                    Classes="headerIconButton"
                                    ToolTip.Tip="Rename project"
                                    IsEnabled="{Binding HasSelectedProject}"
                                    IsVisible="{Binding SelectedProjectRow.IsNotEditing}"
                                    Command="{Binding BeginRenameProjectCommand}"
                                    CommandParameter="{Binding SelectedProjectRow}">
                                <fi:FluentIcon Icon="Edit"
                                               IconVariant="Regular"
                                               IconSize="Size16" />
                            </Button>
                            <Button x:Name="DeleteProjectButton"
                                    Grid.Column="2"
                                    Classes="headerIconButton"
                                    ToolTip.Tip="Delete project"
                                    IsEnabled="{Binding CanDeleteSelectedProject}"
                                    IsVisible="{Binding SelectedProjectRow.IsNotEditing}"
                                    Click="DeleteSelectedProjectButton_OnClick">
                                <fi:FluentIcon Icon="Delete"
                                               IconVariant="Regular"
                                               IconSize="Size16" />
                            </Button>
                            <Button x:Name="RefreshProjectSourcesButton"
                                    Grid.Column="3"
                                    Classes="headerIconButton"
                                    ToolTip.Tip="Refresh all source images in project"
                                    IsEnabled="{Binding HasSelectedProject}"
                                    IsVisible="{Binding SelectedProjectRow.IsNotEditing}"
                                    Click="RefreshSelectedProjectSourcesButton_OnClick">
                                <fi:FluentIcon Icon="FolderSync"
                                               IconVariant="Regular"
                                               IconSize="Size16" />
                            </Button>
                        </Grid>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12"
                                    DataContext="{Binding #Root.((vm:MainWindowViewModel)DataContext)}">
                            <TextBlock Classes="workspaceContextDetail"
                                       Text="{Binding WorkspaceStatus.WorkspaceContextDetail}" />
                            <TextBlock Classes="workspaceContextDetail"
                                       Text="{Binding WorkspaceStatus.WorkspaceActionHint}"
                                       IsVisible="{Binding WorkspaceStatus.ShowWorkspaceActionHint}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <views:ComparisonStage x:Name="ComparisonStage" />

                    <Border x:Name="MainEmptyStateOverlay"
                            IsVisible="{Binding WorkspaceStatus.ShowMainEmptyState}"
                            Background="#D0101010"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            Padding="28"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="MainEmptyStateOverlay_OnDragOver"
                            DragDrop.Drop="MainEmptyStateOverlay_OnDrop">
                        <StackPanel MaxWidth="420"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Classes="emptyStateTitle"
                                       Text="{Binding WorkspaceStatus.MainEmptyStateTitle}" />
                            <TextBlock Classes="emptyStateMessage"
                                       Text="{Binding WorkspaceStatus.MainEmptyStateMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="ImageSetPanel" Grid.Row="3" Grid.Column="2" Background="#161616" BorderBrush="#2B2B2B" BorderThickness="0,1,0,0"
                Padding="18,12">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="12">
                    <TextBlock Classes="imageSetHeaderText"
                               Text="IMAGE SET"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Workspace.SelectedComparisonImageCountText}"
                               Foreground="#A8AFB8"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button x:Name="ToggleImageSetButton"
                            Grid.Column="2"
                            Classes="headerIconButton"
                            ToolTip.Tip="Collapse image set"
                            HorizontalAlignment="Right"
                            Click="ToggleImageSetButton_OnClick">
                        <Grid>
                            <fi:FluentIcon x:Name="CollapseImageSetIcon"
                                           Icon="PanelBottom"
                                           IconVariant="Regular"
                                           IconSize="Size16" />
                            <fi:FluentIcon x:Name="ExpandImageSetIcon"
                                           Icon="PanelBottomExpand"
                                           IconVariant="Regular"
                                           IconSize="Size16"
                                           IsVisible="False" />
                        </Grid>
                    </Button>
                </Grid>

                <ListBox x:Name="ComparisonImagesList"
                         Grid.Row="1"
                         Classes="sidebarList"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ItemsSource="{Binding ImageSet.ImageRows}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ComparisonImageSetItemViewModel">
                            <Border Classes="imageSetCard">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="7">
                                    <Border Classes="imageThumbnailFrame">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   IsVisible="{Binding HasThumbnail}" />
                                            <TextBlock Classes="imageSourceText"
                                                       Text="No preview"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       IsVisible="{Binding HasNoThumbnail}" />
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="5"
                                                        Margin="6"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top">
                                                <Border Classes="roleBadge referenceBadge"
                                                        IsVisible="{Binding IsReference}">
                                                    <TextBlock Classes="roleBadgeText"
                                                               Text="Baseline" />
                                                </Border>
                                                <Border Classes="roleBadge candidateBadge"
                                                        IsVisible="{Binding IsCandidate}">
                                                    <TextBlock Classes="roleBadgeText"
                                                               Text="Candidate" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBox Grid.Row="1"
                                             Classes="inlineImageLabel"
                                             PlaceholderText="Add label"
                                             Text="{Binding DisplayLabel, Mode=TwoWay}"
                                             LostFocus="ImageLabelTextBox_OnLostFocus"
                                             KeyDown="ImageLabelTextBox_OnKeyDown" />

                                    <Grid Grid.Row="2"
                                          RowDefinitions="Auto,Auto"
                                          RowSpacing="2">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Classes="imageVersionText"
                                                       Text="{Binding RevisionText}" />
                                            <TextBlock Classes="imageSourceText"
                                                       Text="{Binding AddedAtText}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1"
                                                   Classes="imageSourceText"
                                                   Text="{Binding MonitoringText}"
                                                   IsVisible="{Binding HasMonitoring}" />
                                    </Grid>

                                    <StackPanel Grid.Row="3"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Spacing="6">
                                        <Button Classes="imageActionIconButton"
                                                ToolTip.Tip="Set as baseline"
                                                IsEnabled="{Binding CanSetReference}"
                                                Background="{Binding BaselineButtonBackground}"
                                                BorderBrush="{Binding BaselineButtonBorderBrush}"
                                                Foreground="{Binding BaselineButtonForeground}"
                                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImageSet.SetReferenceImageAndRefreshCommand}"
                                                CommandParameter="{Binding Image}">
                                            <fi:FluentIcon Icon="Bookmark"
                                                           IconVariant="Regular"
                                                           IconSize="Size16" />
                                        </Button>
                                        <Button Classes="imageActionIconButton"
                                                ToolTip.Tip="Set as candidate"
                                                IsEnabled="{Binding CanSetCandidate}"
                                                Background="{Binding CandidateButtonBackground}"
                                                BorderBrush="{Binding CandidateButtonBorderBrush}"
                                                Foreground="{Binding CandidateButtonForeground}"
                                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImageSet.SetCandidateImageAndRefreshCommand}"
                                                CommandParameter="{Binding Image}">
                                            <fi:FluentIcon Icon="Star"
                                                           IconVariant="Regular"
                                                           IconSize="Size16" />
                                        </Button>
                                        <Button Classes="imageActionIconButton"
                                                ToolTip.Tip="Remove image"
                                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImageSet.DeleteImageAndRefreshCommand}"
                                                CommandParameter="{Binding Image}">
                                            <fi:FluentIcon Icon="Delete"
                                                           IconVariant="Regular"
                                                           IconSize="Size16" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="DifferenceStatusTextBlock"
                           Grid.Row="2"
                           Text="{Binding DifferenceStatusText}"
                           Foreground="#A8AFB8"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
