<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:Difflection.Models"
             xmlns:vm="using:Difflection.ViewModels"
             xmlns:views="using:Difflection.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Difflection.Views.MainView"
             x:DataType="vm:MainWindowViewModel"
             Background="#181818">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.toolbarPrimary">
            <Setter Property="Background" Value="#C2410C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#F97316" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.toolbarSecondary">
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.sidebarIconButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.sidebarIconButton:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Border.viewTab">
            <Setter Property="Padding" Value="0,0,0,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="TextBlock.sidebarHeading">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>
        <Style Selector="ListBox.sidebarList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A2A1F" />
        </Style>
        <Style Selector="TextBlock.sidebarItemText">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBox.nameEditor">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox.inlineImageLabel">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.imageActionButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.viewTabText">
            <Setter Property="Foreground" Value="#A8AFB8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.imageCard">
            <Setter Property="Background" Value="#C40F0F0F" />
            <Setter Property="BorderBrush" Value="#3B3B3B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style Selector="TextBlock.cardLabel">
            <Setter Property="Foreground" Value="#A8AFB8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>
        <Style Selector="TextBlock.cardName">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="34,60,*,Auto" ColumnDefinitions="260,*" Background="#181818">
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#222222" BorderBrush="#353535" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" Margin="14,0">
                <TextBlock Text="Difflection"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Static Image Diff"
                           FontSize="12"
                           Foreground="#8C939D"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#2B2B2B" BorderBrush="#363636" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" Margin="20,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Spacing="28">
                    <Border x:Name="SideBySideViewTab"
                            Classes="viewTab"
                            PointerPressed="SideBySideViewTab_OnPointerPressed">
                        <Grid RowDefinitions="*,2" RowSpacing="6">
                            <TextBlock x:Name="SideBySideViewTabText"
                                       Classes="viewTabText"
                                       Text="Side-by-side"
                                       VerticalAlignment="Center" />
                            <Border x:Name="SideBySideViewTabUnderline"
                                    Grid.Row="1"
                                    Height="2"
                                    Background="#F97316" />
                        </Grid>
                    </Border>
                    <Border x:Name="SplitScreenViewTab"
                            Classes="viewTab"
                            IsEnabled="{Binding CanUseSplitScreen}"
                            PointerPressed="SplitScreenViewTab_OnPointerPressed">
                        <Grid RowDefinitions="*,2" RowSpacing="6">
                            <TextBlock x:Name="SplitScreenViewTabText"
                                       Classes="viewTabText"
                                       Text="Split screen"
                                       VerticalAlignment="Center" />
                            <Border x:Name="SplitScreenViewTabUnderline"
                                    Grid.Row="1"
                                    Height="2"
                                    Background="#F97316" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <Button Classes="toolbarPrimary"
                            Content="Add media"
                            Click="AddMediaButton_OnClick" />
                    <Button Classes="toolbarSecondary"
                            Content="Settings" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.RowSpan="2"
                Grid.Column="0"
                Background="#171717"
                BorderBrush="#303030"
                BorderThickness="0,0,1,0"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto,*,16,Auto,Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                    <TextBlock Classes="sidebarHeading"
                               Text="PROJECTS"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddProjectButton"
                            Grid.Column="1"
                            Classes="sidebarIconButton"
                            Content="+"
                            ToolTip.Tip="Add project"
                            Click="AddProjectButton_OnClick" />
                    <Button x:Name="DeleteProjectButton"
                            Grid.Column="2"
                            Classes="sidebarIconButton"
                            Content="-"
                            ToolTip.Tip="Delete selected project"
                            IsEnabled="{Binding CanDeleteSelectedProject}"
                            Click="DeleteProjectButton_OnClick" />
                </Grid>

                <TextBox x:Name="ProjectNameTextBox"
                         Grid.Row="1"
                         Classes="nameEditor"
                         PlaceholderText="Project name"
                         IsEnabled="{Binding HasSelectedProject}"
                         Text="{Binding SelectedProjectName, Mode=TwoWay}"
                         LostFocus="ProjectNameTextBox_OnLostFocus"
                         KeyDown="ProjectNameTextBox_OnKeyDown" />

                <ListBox x:Name="ProjectsList"
                         Grid.Row="2"
                         Classes="sidebarList"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Project">
                            <TextBlock Classes="sidebarItemText"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="3" Height="1" Background="#303030" VerticalAlignment="Center" />

                <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                    <TextBlock Classes="sidebarHeading"
                               Text="COMPARISONS"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddComparisonButton"
                            Grid.Column="1"
                            Classes="sidebarIconButton"
                            Content="+"
                            ToolTip.Tip="Add comparison"
                            IsEnabled="{Binding CanAddComparison}"
                            Click="AddComparisonButton_OnClick" />
                    <Button x:Name="DeleteComparisonButton"
                            Grid.Column="2"
                            Classes="sidebarIconButton"
                            Content="-"
                            ToolTip.Tip="Delete selected comparison"
                            IsEnabled="{Binding CanDeleteSelectedComparison}"
                            Click="DeleteComparisonButton_OnClick" />
                </Grid>

                <TextBox x:Name="ComparisonNameTextBox"
                         Grid.Row="5"
                         Classes="nameEditor"
                         PlaceholderText="Comparison name"
                         IsEnabled="{Binding HasSelectedComparison}"
                         Text="{Binding SelectedComparisonName, Mode=TwoWay}"
                         LostFocus="ComparisonNameTextBox_OnLostFocus"
                         KeyDown="ComparisonNameTextBox_OnKeyDown" />

                <ListBox x:Name="ComparisonsList"
                         Grid.Row="6"
                         Classes="sidebarList"
                         ItemsSource="{Binding SelectedProjectComparisons}"
                         SelectedItem="{Binding SelectedComparison, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ComparisonSet">
                            <TextBlock Classes="sidebarItemText"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Background="#101010" Padding="24">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <TextBlock x:Name="DropHintBanner"
                               Text="Drop images below to begin."
                               Foreground="#9AA1AB"
                               FontSize="22"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SplitPercentageText}"
                               IsVisible="{Binding IsSplitScreenView}"
                               Foreground="#BFC4CC"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="Zoom"
                               Foreground="#AEB4BC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="ZoomTextBox"
                             Grid.Column="3"
                             Width="84"
                             Text="{Binding ZoomText, Mode=TwoWay}"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Center"
                             LostFocus="ZoomTextBox_OnLostFocus"
                             KeyDown="ZoomTextBox_OnKeyDown" />
                </Grid>

                <views:ComparisonStage x:Name="ComparisonStage"
                                       Grid.Row="1" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Grid.Column="1" Background="#161616" BorderBrush="#2B2B2B" BorderThickness="0,1,0,0" Padding="18,12">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Classes="sidebarHeading"
                               Text="IMAGE SET"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddImageToSetButton"
                            Grid.Column="1"
                            Classes="toolbarSecondary"
                            Content="Add image"
                            Click="AddMediaButton_OnClick" />
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="14">
                    <Border Classes="imageCard"
                            Width="320"
                            IsVisible="{Binding HasLeftImage}">
                        <Grid ColumnDefinitions="72,*" ColumnSpacing="12">
                            <Border Width="72" Height="48" Background="#111827" CornerRadius="4" ClipToBounds="True">
                                <Image Source="{Binding LeftImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapInterpolationMode="None" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Classes="cardLabel" Text="REFERENCE" />
                                <TextBlock Classes="cardName" Text="{Binding LeftFileName}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="imageCard"
                            Width="320"
                            IsVisible="{Binding HasRightImage}">
                        <Grid ColumnDefinitions="72,*" ColumnSpacing="12">
                            <Border Width="72" Height="48" Background="#111827" CornerRadius="4" ClipToBounds="True">
                                <Image Source="{Binding RightImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapInterpolationMode="None" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Classes="cardLabel" Text="CANDIDATE" />
                                <TextBlock Classes="cardName" Text="{Binding RightFileName}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <ListBox x:Name="ComparisonImagesList"
                         Grid.Row="2"
                         Classes="sidebarList"
                         MaxHeight="132"
                         ItemsSource="{Binding SelectedComparisonImages}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ImageAsset">
                            <Grid ColumnDefinitions="180,*,Auto,Auto,Auto" ColumnSpacing="8" Margin="0,2">
                                <TextBox Classes="inlineImageLabel"
                                         Text="{Binding Label, Mode=TwoWay}"
                                         LostFocus="ImageLabelTextBox_OnLostFocus"
                                         KeyDown="ImageLabelTextBox_OnKeyDown" />
                                <TextBlock Grid.Column="1"
                                           Classes="sidebarItemText"
                                           Text="{Binding SourceName}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Classes="imageActionButton"
                                        Content="Reference"
                                        Click="SetReferenceImageButton_OnClick" />
                                <Button Grid.Column="3"
                                        Classes="imageActionButton"
                                        Content="Candidate"
                                        Click="SetCandidateImageButton_OnClick" />
                                <Button Grid.Column="4"
                                        Classes="imageActionButton"
                                        Content="Remove"
                                        Click="DeleteImageButton_OnClick" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="3"
                           Text="{Binding DifferenceStatusText}"
                           Foreground="#A8AFB8"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
