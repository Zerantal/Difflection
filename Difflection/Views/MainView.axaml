<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Difflection.ViewModels"
             xmlns:views="using:Difflection.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Difflection.Views.MainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel"
             Background="#181818">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.toolbarPrimary">
            <Setter Property="Background" Value="#C2410C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#F97316" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.toolbarSecondary">
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.sidebarIconButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.sidebarIconButton:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Border.viewTab">
            <Setter Property="Padding" Value="0,0,0,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="TextBlock.sidebarHeading">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>
        <Style Selector="ListBox.sidebarList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A2A1F" />
        </Style>
        <Style Selector="TextBlock.sidebarItemText">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBox.nameEditor">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox.sidebarInlineName">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="TextBox.sidebarInlineName:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TextBox.sidebarInlineName.editing">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#525252" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
        <Style Selector="TextBox.inlineImageLabel">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.imageActionButton">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.viewTabText">
            <Setter Property="Foreground" Value="#A8AFB8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.imageSetCard">
            <Setter Property="Background" Value="#121212" />
            <Setter Property="BorderBrush" Value="#383838" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Width" Value="320" />
            <Setter Property="MinHeight" Value="159" />
        </Style>
        <Style Selector="Border.roleBadge">
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <Style Selector="Border.referenceBadge">
            <Setter Property="Background" Value="#3A2A1F" />
            <Setter Property="BorderBrush" Value="#F97316" />
        </Style>
        <Style Selector="Border.candidateBadge">
            <Setter Property="Background" Value="#1F2C3A" />
            <Setter Property="BorderBrush" Value="#38BDF8" />
        </Style>
        <Style Selector="TextBlock.roleBadgeText">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.imageSourceText">
            <Setter Property="Foreground" Value="#8C939D" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.workspaceContextTitle">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.workspaceContextDetail">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.emptyStateTitle">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.emptyStateMessage">
            <Setter Property="Foreground" Value="#9AA1AB" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.sidebarEmptyText">
            <Setter Property="Foreground" Value="#737B86" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="8,8,8,0" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="34,60,*,Auto" ColumnDefinitions="260,*" Background="#181818">
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#222222" BorderBrush="#353535" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" Margin="14,0">
                <TextBlock Text="Difflection"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#E5E7EB"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Static Image Diff"
                           FontSize="12"
                           Foreground="#8C939D"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0" Background="#2B2B2B" BorderBrush="#363636" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" Margin="20,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Spacing="28">
                    <Border x:Name="SideBySideViewTab"
                            Classes="viewTab"
                            PointerPressed="SideBySideViewTab_OnPointerPressed">
                        <Grid RowDefinitions="*,2" RowSpacing="6">
                            <TextBlock x:Name="SideBySideViewTabText"
                                       Classes="viewTabText"
                                       Text="Side-by-side"
                                       VerticalAlignment="Center" />
                            <Border x:Name="SideBySideViewTabUnderline"
                                    Grid.Row="1"
                                    Height="2"
                                    Background="#F97316" />
                        </Grid>
                    </Border>
                    <Border x:Name="SplitScreenViewTab"
                            Classes="viewTab"
                            IsEnabled="{Binding ToolState.CanUseSplitScreen}"
                            PointerPressed="SplitScreenViewTab_OnPointerPressed">
                        <Grid RowDefinitions="*,2" RowSpacing="6">
                            <TextBlock x:Name="SplitScreenViewTabText"
                                       Classes="viewTabText"
                                       Text="Split screen"
                                       VerticalAlignment="Center" />
                            <Border x:Name="SplitScreenViewTabUnderline"
                                    Grid.Row="1"
                                    Height="2"
                                    Background="#F97316" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <Button Classes="toolbarPrimary"
                            Content="Add media"
                            Click="AddMediaButton_OnClick" />
                    <Button Classes="toolbarSecondary"
                            Content="Settings" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.RowSpan="2"
                Grid.Column="0"
                Background="#171717"
                BorderBrush="#303030"
                BorderThickness="0,0,1,0"
                Padding="12"
                DataContext="{Binding Workspace}">
            <Grid RowDefinitions="Auto,*,16,Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBlock Classes="sidebarHeading"
                               Text="PROJECTS"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddProjectButton"
                            Grid.Column="1"
                            Classes="sidebarIconButton"
                            Content="+"
                            ToolTip.Tip="Add project"
                            Command="{Binding AddProjectForInlineRenameCommand}" />
                </Grid>

                <ListBox x:Name="ProjectsList"
                         Grid.Row="1"
                         Classes="sidebarList"
                         ItemsSource="{Binding ProjectRows}"
                         SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectListItemViewModel">
                            <Border Background="Transparent"
                                    ContextRequested="SidebarItem_OnContextRequested">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Refresh source images"
                                                  Click="RefreshProjectSourcesMenuItem_OnClick" />
                                        <MenuItem Header="Rename" />
                                        <MenuItem Header="Delete"
                                                  Click="DeleteProjectMenuItem_OnClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <TextBlock Classes="sidebarItemText"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsNotEditing}" />
                                    <TextBox Classes="sidebarInlineName editing"
                                             Text="{Binding DraftName, Mode=TwoWay}"
                                             IsVisible="{Binding IsEditing}"
                                             AttachedToVisualTree="InlineNameTextBox_OnAttachedToVisualTree"
                                             PropertyChanged="InlineNameTextBox_OnPropertyChanged"
                                             LostFocus="ProjectListNameTextBox_OnLostFocus"
                                             KeyDown="ProjectListNameTextBox_OnKeyDown" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="1"
                           Classes="sidebarEmptyText"
                           Text="No projects yet."
                           IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).WorkspaceStatus.ShowProjectsEmptyState}" />

                <Border Grid.Row="2" Height="1" Background="#303030" VerticalAlignment="Center" />

                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBlock Classes="sidebarHeading"
                               Text="COMPARISONS"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddComparisonButton"
                            Grid.Column="1"
                            Classes="sidebarIconButton"
                            Content="+"
                            ToolTip.Tip="Add comparison"
                            IsEnabled="{Binding CanAddComparison}"
                            Command="{Binding AddComparisonForInlineRenameCommand}" />
                </Grid>

                <ListBox x:Name="ComparisonsList"
                         Grid.Row="4"
                         Classes="sidebarList"
                         ItemsSource="{Binding SelectedProjectComparisonRows}"
                         SelectedItem="{Binding SelectedComparisonRow, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ComparisonListItemViewModel">
                            <Border Background="Transparent"
                                    ContextRequested="SidebarItem_OnContextRequested">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Refresh source images"
                                                  Click="RefreshComparisonSourcesMenuItem_OnClick" />
                                        <MenuItem Header="Rename" />
                                        <MenuItem Header="Delete"
                                                  Click="DeleteComparisonMenuItem_OnClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <TextBlock Classes="sidebarItemText"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsNotEditing}" />
                                    <TextBox Classes="sidebarInlineName editing"
                                             Text="{Binding DraftName, Mode=TwoWay}"
                                             IsVisible="{Binding IsEditing}"
                                             AttachedToVisualTree="InlineNameTextBox_OnAttachedToVisualTree"
                                             PropertyChanged="InlineNameTextBox_OnPropertyChanged"
                                             LostFocus="ComparisonListNameTextBox_OnLostFocus"
                                             KeyDown="ComparisonListNameTextBox_OnKeyDown" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="4"
                           Classes="sidebarEmptyText"
                           Text="No comparisons in this project."
                           IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).WorkspaceStatus.ShowComparisonsEmptyState}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Background="#101010" Padding="24">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Classes="workspaceContextTitle"
                                   Text="{Binding WorkspaceStatus.WorkspaceContextTitle}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12">
                            <TextBlock Classes="workspaceContextDetail"
                                       Text="{Binding WorkspaceStatus.WorkspaceContextDetail}" />
                            <TextBlock Classes="workspaceContextDetail"
                                       Text="{Binding WorkspaceStatus.WorkspaceActionHint}"
                                       IsVisible="{Binding WorkspaceStatus.ShowWorkspaceActionHint}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ToolState.SplitPercentageText}"
                               IsVisible="{Binding ToolState.IsSplitScreenView}"
                               Foreground="#BFC4CC"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="Zoom"
                               Foreground="#AEB4BC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="ZoomTextBox"
                             Grid.Column="3"
                             Width="84"
                             Text="{Binding ToolState.ZoomText, Mode=TwoWay}"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Center"
                             LostFocus="ZoomTextBox_OnLostFocus"
                             KeyDown="ZoomTextBox_OnKeyDown" />
                </Grid>

                <Grid Grid.Row="1">
                    <views:ComparisonStage x:Name="ComparisonStage" />

                    <Border x:Name="MainEmptyStateOverlay"
                            IsVisible="{Binding WorkspaceStatus.ShowMainEmptyState}"
                            Background="#D0101010"
                            BorderBrush="#262626"
                            BorderThickness="1"
                            Padding="28"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="MainEmptyStateOverlay_OnDragOver"
                            DragDrop.Drop="MainEmptyStateOverlay_OnDrop">
                        <StackPanel MaxWidth="420"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Classes="emptyStateTitle"
                                       Text="{Binding WorkspaceStatus.MainEmptyStateTitle}" />
                            <TextBlock Classes="emptyStateMessage"
                                       Text="{Binding WorkspaceStatus.MainEmptyStateMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Grid.Column="1" Background="#161616" BorderBrush="#2B2B2B" BorderThickness="0,1,0,0" Padding="18,12">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Classes="sidebarHeading"
                               Text="IMAGE SET"
                               VerticalAlignment="Center" />
                    <Button x:Name="AddImageToSetButton"
                            Grid.Column="1"
                            Classes="toolbarSecondary"
                            Content="Add image"
                            Click="AddMediaButton_OnClick" />
                </Grid>

                <ListBox x:Name="ComparisonImagesList"
                         Grid.Row="1"
                         Classes="sidebarList"
                         MaxHeight="197"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemsSource="{Binding ImageSet.ImageRows}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ComparisonImageSetItemViewModel">
                            <Border Classes="imageSetCard" Margin="0,0,10,10">
                                <Grid ColumnDefinitions="76,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="7">
                                    <Border Background="#0A0A0A"
                                            BorderBrush="#282828"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            ClipToBounds="True"
                                            Width="76"
                                            Height="58"
                                            VerticalAlignment="Top">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   IsVisible="{Binding HasThumbnail}" />
                                            <TextBlock Classes="imageSourceText"
                                                       Text="No preview"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       IsVisible="{Binding HasNoThumbnail}" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                        <TextBox Classes="inlineImageLabel"
                                                 Text="{Binding Label, Mode=TwoWay}"
                                                 LostFocus="ImageLabelTextBox_OnLostFocus"
                                                 KeyDown="ImageLabelTextBox_OnKeyDown" />
                                        <TextBlock Classes="imageSourceText"
                                                   Text="{Binding SourceName}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                        <Border Classes="roleBadge referenceBadge"
                                                IsVisible="{Binding IsReference}">
                                            <TextBlock Classes="roleBadgeText" Text="REFERENCE" />
                                        </Border>
                                        <Border Classes="roleBadge candidateBadge"
                                                IsVisible="{Binding IsCandidate}">
                                            <TextBlock Classes="roleBadgeText" Text="CANDIDATE" />
                                        </Border>
                                        <Border Classes="roleBadge"
                                                IsVisible="{Binding HasMonitoring}">
                                            <TextBlock Classes="roleBadgeText" Text="{Binding MonitoringText}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="6">
                                        <Button Classes="imageActionButton"
                                                Content="Reference"
                                                IsEnabled="{Binding CanSetReference}"
                                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImageSet.SetReferenceImageAndRefreshCommand}"
                                                CommandParameter="{Binding Image}" />
                                        <Button Classes="imageActionButton"
                                                Content="Candidate"
                                                IsEnabled="{Binding CanSetCandidate}"
                                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImageSet.SetCandidateImageAndRefreshCommand}"
                                                CommandParameter="{Binding Image}" />
                                        <Button Classes="imageActionButton"
                                                Content="Remove"
                                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImageSet.DeleteImageAndRefreshCommand}"
                                                CommandParameter="{Binding Image}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2"
                           Text="{Binding DifferenceStatusText}"
                           Foreground="#A8AFB8"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
