<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="using:Difflection.Infrastructure"
             xmlns:vm="using:Difflection.ViewModels"
             xmlns:views="using:Difflection.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Difflection.Views.MainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource AppBackgroundBrush}">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <StyleInclude Source="avares://Difflection/Styles/Workspace.axaml" />
    </UserControl.Styles>

    <Grid x:Name="RootGrid"
          RowDefinitions="34,60,*,Auto"
          ColumnDefinitions="260,5,*"
          Background="{DynamicResource AppBackgroundBrush}">
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="{DynamicResource TopBarBackgroundBrush}"
                BorderBrush="{DynamicResource TopBarBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*"
                  Margin="14,0">
                <TextBlock Text="Difflection"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Static Image Diff"
                           FontSize="12"
                           Foreground="{DynamicResource TextSubtleBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,1,1" />

        <Border Grid.Row="1"
                Grid.Column="2"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HeaderBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12"
                  Margin="12,0"
                  DataContext="{Binding Workspace}">
                <StackPanel Spacing="3"
                            VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*"
                          ColumnSpacing="8">
                        <TextBlock Classes="workspaceContextTitle"
                                   Text="{Binding SelectedProjectName}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding SelectedProjectRow?.IsNotEditing}" />
                        <TextBlock Grid.Column="0" Classes="workspaceContextTitle"
                                   Text="No project selected"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding ShowProjectsEmptyState}" />
                        <Grid Grid.Column="0"
                              IsVisible="{Binding SelectedProjectRow.IsEditing, TargetNullValue=False, FallbackValue=False}">
                            <TextBox x:Name="ProjectNameTextBox"
                                     Classes="nameEditor"
                                     MinWidth="260"
                                     DataContext="{Binding #Root.((vm:MainWindowViewModel)DataContext)?.Workspace.SelectedProjectRow}"
                                     Text="{Binding DraftName, Mode=TwoWay}"
                                     infra:InlineRenameTextBoxBehavior.IsEnabled="True"
                                     infra:InlineRenameTextBoxBehavior.CommitCommand="{Binding #Root.((vm:MainWindowViewModel)DataContext)?.Workspace.CommitProjectRenameCommand}"
                                     infra:InlineRenameTextBoxBehavior.CancelCommand="{Binding #Root.((vm:MainWindowViewModel)DataContext)?.Workspace.CancelProjectRenameEditCommand}" />
                        </Grid>
                        <Button x:Name="EditProjectButton"
                                Grid.Column="1"
                                Classes="headerIconButton"
                                ToolTip.Tip="Rename project"
                                IsEnabled="{Binding HasSelectedProject}"
                                IsVisible="{Binding SelectedProjectRow?.IsNotEditing}"
                                Command="{Binding BeginRenameProjectCommand}"
                                CommandParameter="{Binding SelectedProjectRow}">
                            <PathIcon Data="{StaticResource Icon.Edit}"
                                      Width="16"
                                      Height="16" />
                        </Button>
                        <Button x:Name="RefreshProjectSourcesButton"
                                Grid.Column="2"
                                Classes="headerIconButton"
                                ToolTip.Tip="Refresh all source images in project"
                                IsEnabled="{Binding HasSelectedProject}"
                                IsVisible="{Binding SelectedProjectRow?.IsNotEditing}"
                                Click="RefreshSelectedProjectSourcesButton_OnClick">
                            <PathIcon Data="{StaticResource Icon.Refresh}"
                                      Width="16"
                                      Height="16" />
                        </Button>
                        <Button x:Name="DeleteProjectButton"
                                Grid.Column="3"
                                Classes="headerIconButton"
                                ToolTip.Tip="Delete project"
                                IsEnabled="{Binding CanDeleteSelectedProject}"
                                IsVisible="{Binding SelectedProjectRow?.IsNotEditing}"
                                Click="DeleteSelectedProjectButton_OnClick">
                            <PathIcon Data="{StaticResource Icon.Delete}"
                                      Width="16"
                                      Height="16" />
                        </Button>
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                DataContext="{Binding #Root.((vm:MainWindowViewModel)DataContext)}">
                        <TextBlock Classes="workspaceContextDetail"
                                   Text="{Binding WorkspaceStatus.WorkspaceContextDetail}" />
                        <TextBlock Classes="workspaceContextDetail"
                                   Text="{Binding WorkspaceStatus.WorkspaceActionHint}"
                                   IsVisible="{Binding WorkspaceStatus.ShowWorkspaceActionHint}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <Button x:Name="SettingsButton"
                            Classes="headerIconButton"
                            ToolTip.Tip="Settings"
                            IsVisible="{Binding SelectedProjectRow?.IsNotEditing}"
                            Click="SettingsButton_OnClick">
                        <PathIcon Data="{StaticResource Icon.Settings}"
                                  Width="16"
                                  Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.RowSpan="3"
                      Grid.Column="1"
                      Background="{DynamicResource DividerBrush}"
                      BorderBrush="{DynamicResource SplitterBorderBrush}"
                      BorderThickness="1,0"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <views:WorkspaceSidebar Grid.Row="2"
                                Grid.RowSpan="2"
                                Grid.Column="0"
                                x:Name="WorkspaceSidebarHost" />

        <Border Grid.Row="2"
                Grid.Column="2"
                Background="{DynamicResource WorkspaceBackgroundBrush}"
                Padding="16">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">
                <views:TopToolbar Grid.Row="0"
                                  x:Name="TopToolbarHost" />

                <Grid Grid.Row="1">
                    <views:ComparisonStage x:Name="ComparisonStage" />

                    <Border x:Name="MainEmptyStateOverlay"
                            IsVisible="{Binding WorkspaceStatus.ShowMainEmptyState}"
                            Background="{DynamicResource OverlayBackgroundBrush}"
                            BorderBrush="{DynamicResource SurfaceRaisedBrush}"
                            BorderThickness="1"
                            Padding="28"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="MainEmptyStateOverlay_OnDragOver"
                            DragDrop.Drop="MainEmptyStateOverlay_OnDrop">
                        <StackPanel MaxWidth="420"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Classes="emptyStateTitle"
                                       Text="{Binding WorkspaceStatus.MainEmptyStateTitle}" />
                            <TextBlock Classes="emptyStateMessage"
                                       Text="{Binding WorkspaceStatus.MainEmptyStateMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <views:ImageSetPanel Grid.Row="3"
                             Grid.Column="2"
                             x:Name="ImageSetPanelHost" />
    </Grid>
</UserControl>
