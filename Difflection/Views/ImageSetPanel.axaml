<!-- ReSharper disable Xaml.StyleClassNotFound -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Difflection.ViewModels"
             x:Class="Difflection.Views.ImageSetPanel"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel"
             Background="Transparent">
    <Border x:Name="PanelBorder"
            Background="#161616"
            BorderBrush="#2B2B2B"
            BorderThickness="0,1,0,0"
            Padding="18,12">
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Classes="imageSetHeaderText"
                           Text="IMAGE SET"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Workspace.SelectedComparisonImageCountText}"
                           Foreground="#A8AFB8"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="ToggleImageSetButton"
                        Grid.Column="2"
                        Classes="headerIconButton"
                        ToolTip.Tip="Collapse image set"
                        HorizontalAlignment="Right"
                        Click="ToggleImageSetButton_OnClick">
                    <Grid>
                        <PathIcon x:Name="CollapseImageSetIcon"
                                  Data="{StaticResource Icon.ChevronDown}"
                                  Width="16"
                                  Height="16" />
                        <PathIcon x:Name="ExpandImageSetIcon"
                                  Data="{StaticResource Icon.ChevronUp}"
                                  Width="16"
                                  Height="16"
                                  IsVisible="False" />
                    </Grid>
                </Button>
            </Grid>

            <ListBox x:Name="ComparisonImagesList"
                     Grid.Row="1"
                     Classes="sidebarList"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ItemsSource="{Binding ImageSet.ImageRows}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ComparisonImageSetItemViewModel">
                        <Border Classes="imageSetCard">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="7">
                                <Border Classes="imageThumbnailFrame">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapInterpolationMode="None"
                                               IsVisible="{Binding HasThumbnail}" />
                                        <TextBlock Classes="imageSourceText"
                                                   Text="No preview"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   IsVisible="{Binding HasNoThumbnail}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="5"
                                                    Margin="6"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top">
                                            <Border Classes="roleBadge referenceBadge"
                                                    IsVisible="{Binding IsReference}">
                                                <TextBlock Classes="roleBadgeText"
                                                           Text="Baseline" />
                                            </Border>
                                            <Border Classes="roleBadge candidateBadge"
                                                    IsVisible="{Binding IsCandidate}">
                                                <TextBlock Classes="roleBadgeText"
                                                           Text="Candidate" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBox Grid.Row="1"
                                         Classes="inlineImageLabel"
                                         PlaceholderText="Add label"
                                         Text="{Binding DisplayLabel, Mode=TwoWay}"
                                         LostFocus="ImageLabelTextBox_OnLostFocus"
                                         KeyDown="ImageLabelTextBox_OnKeyDown" />

                                <Grid Grid.Row="2"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="2">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Classes="imageVersionText"
                                                   Text="{Binding RevisionText}" />
                                        <TextBlock Classes="imageSourceText"
                                                   Text="{Binding AddedAtText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               Classes="imageSourceText"
                                               Text="{Binding MonitoringText}"
                                               IsVisible="{Binding HasMonitoring}" />
                                </Grid>

                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <Button Classes="imageActionIconButton"
                                            ToolTip.Tip="Set as baseline"
                                            IsEnabled="{Binding CanSetReference}"
                                            Background="{Binding BaselineButtonBackground}"
                                            BorderBrush="{Binding BaselineButtonBorderBrush}"
                                            Foreground="{Binding BaselineButtonForeground}"
                                            Command="{Binding #Root.((vm:MainWindowViewModel)DataContext)?.ImageSet.SetReferenceImageAndRefreshCommand}"
                                            CommandParameter="{Binding Image}">
                                        <PathIcon Data="{StaticResource Icon.Bookmark}"
                                                  Width="16"
                                                  Height="16" />
                                    </Button>
                                    <Button Classes="imageActionIconButton"
                                            ToolTip.Tip="Set as candidate"
                                            IsEnabled="{Binding CanSetCandidate}"
                                            Background="{Binding CandidateButtonBackground}"
                                            BorderBrush="{Binding CandidateButtonBorderBrush}"
                                            Foreground="{Binding CandidateButtonForeground}"
                                            Command="{Binding #Root.((vm:MainWindowViewModel)DataContext)?.ImageSet.SetCandidateImageAndRefreshCommand}"
                                            CommandParameter="{Binding Image}">
                                        <PathIcon Data="{StaticResource Icon.Star}"
                                                  Width="16"
                                                  Height="16" />
                                    </Button>
                                    <Button Classes="imageActionIconButton"
                                            ToolTip.Tip="Remove image"
                                            Command="{Binding #Root.((vm:MainWindowViewModel)DataContext)?.ImageSet.DeleteImageAndRefreshCommand}"
                                            CommandParameter="{Binding Image}">
                                        <PathIcon Data="{StaticResource Icon.Delete}"
                                                  Width="16"
                                                  Height="16" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock x:Name="DifferenceStatusTextBlock"
                       Grid.Row="2"
                       Text="{Binding DifferenceStatusText}"
                       Foreground="#A8AFB8"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</UserControl>
