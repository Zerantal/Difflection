<!-- ReSharper disable Xaml.StyleClassNotFound -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Difflection.ViewModels"
             xmlns:views="using:Difflection.Views"
             x:Class="Difflection.Views.ImageSetPanel"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel"
             Background="Transparent">
    <Border x:Name="PanelBorder"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="18,10">
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Classes="imageSetTitleText"
                           Text="Image Channels"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Workspace.SelectedComparisonImageCountText}"
                           Foreground="{DynamicResource TextInteractiveBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2"
                        Classes="headerIconButton"
                        ToolTip.Tip="Clear inactive revisions"
                        HorizontalAlignment="Right"
                        IsEnabled="{Binding ImageSet.CanClearNonRoleImages}"
                        Command="{Binding ImageSet.ClearNonRoleImagesAndRefreshCommand}">
                    <PathIcon Data="{StaticResource Icon.Delete}"
                              Width="16"
                              Height="16" />
                </Button>
                <Button x:Name="ToggleImageSetButton"
                        Grid.Column="3"
                        Classes="headerIconButton"
                        ToolTip.Tip="Collapse image set"
                        HorizontalAlignment="Right"
                        Click="ToggleImageSetButton_OnClick">
                    <Grid>
                        <PathIcon x:Name="CollapseImageSetIcon"
                                  Data="{StaticResource Icon.ChevronDown}"
                                  Width="16"
                                  Height="16" />
                        <PathIcon x:Name="ExpandImageSetIcon"
                                  Data="{StaticResource Icon.ChevronUp}"
                                  Width="16"
                                  Height="16"
                                  IsVisible="False" />
                    </Grid>
                </Button>
            </Grid>

            <Grid x:Name="ComparisonImagesList"
                  Grid.Row="1"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8">
                <views:ImageChannelFrame ChannelName="Baseline"
                                         ListName="BaselineRevisionsList"
                                         IsBaselineChannel="True"
                                         IsVisible="{Binding ImageSet.HasBaselineRevisionRows}"
                                         Items="{Binding ImageSet.BaselineRevisionRows}" />

                <views:ImageChannelFrame Grid.Row="1"
                                         ChannelName="Candidate"
                                         ListName="CandidateRevisionsList"
                                         IsCandidateChannel="True"
                                         IsVisible="{Binding ImageSet.HasCandidateRevisionRows}"
                                         Items="{Binding ImageSet.CandidateRevisionRows}" />
            </Grid>

            <TextBlock x:Name="DifferenceStatusTextBlock"
                       Grid.Row="2"
                       Text="{Binding DifferenceStatusText}"
                       Foreground="{DynamicResource TextInteractiveBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</UserControl>
