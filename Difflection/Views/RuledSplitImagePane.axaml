<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Difflection.Views"
             x:Class="Difflection.Views.RuledSplitImagePane"
             x:Name="Root"
             Background="{DynamicResource RulerBackgroundBrush}">

    <UserControl.Styles>
        <Style Selector="Border.imageLayer">
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
    </UserControl.Styles>
    
    <Grid x:Name="PaneRoot"
          ClipToBounds="True"
          RowDefinitions="24,28,*"
          ColumnDefinitions="44,*"
          Background="{DynamicResource RulerBackgroundBrush}"
          DragDrop.AllowDrop="True"
          DragDrop.DragOver="Pane_OnDragOver"
          DragDrop.Drop="Pane_OnDrop">
        <Border Background="{DynamicResource RulerBackgroundBrush}"
                BorderBrush="{DynamicResource RulerBorderBrush}"
                BorderThickness="0,0,1,1"
                IsHitTestVisible="False" />

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="{DynamicResource SplitSurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource HoverBackgroundBrush}"
                BorderThickness="0,0,0,1"
                IsHitTestVisible="False">
            <Grid Margin="8,0">
                <Border Background="{DynamicResource WorkspaceBackgroundBrush}"
                        BorderBrush="{DynamicResource BaselineBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <TextBlock Text="Baseline"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border Background="{DynamicResource WorkspaceBackgroundBrush}"
                        BorderBrush="{DynamicResource CandidateBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <TextBlock Text="Candidate"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="0"
                Background="{DynamicResource SplitSurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource RulerBorderBrush}"
                BorderThickness="0,0,1,1"
                IsHitTestVisible="False" />

        <views:PixelRuler Grid.Row="1"
                          Grid.Column="1"
                          x:Name="TopRuler"
                          Height="28"
                          Orientation="Horizontal"
                          Mode="Continuous"
                          Background="{DynamicResource RulerBackgroundBrush}"
                          BorderBrush="{DynamicResource RulerBorderBrush}"
                          MajorTickBrush="{DynamicResource RulerMajorTickBrush}"
                          MinorTickBrush="{DynamicResource RulerMinorTickBrush}"
                          Foreground="{DynamicResource RulerTextBrush}"
                          IsHitTestVisible="False" />

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource RulerBackgroundBrush}"
                BorderBrush="{DynamicResource RulerBorderBrush}"
                BorderThickness="0,0,1,1"
                IsHitTestVisible="False" />

        <views:PixelRuler Grid.Row="2"
                          Grid.Column="0"
                          x:Name="LeftRuler"
                          Width="44"
                          Orientation="Vertical"
                          Mode="Continuous"
                          Background="{DynamicResource RulerBackgroundBrush}"
                          BorderBrush="{DynamicResource RulerBorderBrush}"
                          MajorTickBrush="{DynamicResource RulerMajorTickBrush}"
                          MinorTickBrush="{DynamicResource RulerMinorTickBrush}"
                          Foreground="{DynamicResource RulerTextBrush}"
                          IsHitTestVisible="False" />

        <Border Grid.Row="2"
                Grid.Column="1"
                BorderBrush="{DynamicResource BorderStageBrush}"
                BorderThickness="1"
                Background="{DynamicResource ImageCanvasBrush}">
            <Grid x:Name="SplitPaneRoot"
                  ClipToBounds="True">
                <ScrollViewer x:Name="ScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="ScrollViewer_OnScrollChanged"
                              Background="{StaticResource ImageViewportFillBrush}">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <LayoutTransformControl x:Name="Transform">
                            <LayoutTransformControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomScale, ElementName=Root}"
                                                ScaleY="{Binding ZoomScale, ElementName=Root}" />
                            </LayoutTransformControl.LayoutTransform>
                            <Grid x:Name="Surface"
                                  Width="{Binding SurfaceWidth, ElementName=Root}"
                                  Height="{Binding SurfaceHeight, ElementName=Root}"
                                  ClipToBounds="True"
                                  SizeChanged="Surface_OnSizeChanged">
                                <Border Background="Transparent" />

                                <Border x:Name="LeftImageLayer"
                                        Classes="imageLayer">
                                    <Image Source="{Binding LeftImage, ElementName=Root}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapInterpolationMode="None" />
                                </Border>

                                <Border x:Name="RightImageLayer"
                                        Classes="imageLayer">
                                    <Image Source="{Binding RightImage, ElementName=Root}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapInterpolationMode="None" />
                                </Border>

                                <Border x:Name="SplitDivider"
                                        Width="1"
                                        Background="{DynamicResource SplitHandleBrush}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        IsHitTestVisible="False"
                                        ZIndex="10" />
                                <Border x:Name="SplitDragSurface"
                                        Width="24"
                                        Background="Transparent"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Cursor="SizeWestEast"
                                        PointerPressed="SplitDivider_OnPointerPressed"
                                        PointerMoved="OnPointerMoved"
                                        PointerReleased="OnPointerReleased"
                                        ZIndex="11" />
                            </Grid>
                        </LayoutTransformControl>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
