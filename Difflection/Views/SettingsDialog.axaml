<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Difflection.Views.SettingsDialog"
        Background="{DynamicResource AppBackgroundBrush}"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        Title="Settings"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,Auto"
          RowSpacing="18"
          Margin="20">
        <StackPanel Spacing="14">
            <TextBlock Text="Settings"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <Border Background="{DynamicResource WorkspaceBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderMutedBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <TextBlock Text="Theme"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="ThemePreferenceComboBox"
                                  Grid.Column="1"
                                  MinWidth="150"
                                  HorizontalAlignment="Left"
                                  ToolTip.Tip="Sync with OS follows the current operating system appearance setting.">
                            <ComboBoxItem Content="Sync with OS" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="MonitorSourceFilesCheckBox"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="13"
                              Content="Monitor source files"
                              ToolTip.Tip="Watch source folders for local image changes and add changed files to the current project." />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel"
                    Padding="16,7"
                    Click="CancelButton_OnClick" />
            <Button Content="Save"
                    Padding="18,7"
                    Click="SaveButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
