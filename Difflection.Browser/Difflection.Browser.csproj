<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0-browser</TargetFramework>
        <Nullable>enable</Nullable>
        <WasmMainHTMLPath>wwwroot/index.html</WasmMainHTMLPath>
        <WasmMainJSPath>wwwroot/main.js</WasmMainJSPath>
        <DefaultWasmHostConfig>browser</DefaultWasmHostConfig>
        <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    </PropertyGroup>

    <ItemGroup>
        <HostConfig Include="browser">
            <host>browser</host>
        </HostConfig>
        <WasmExtraFilesToDeploy Include="wwwroot/app.css" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia.Browser" Version="12.0.999-cibuild0064469-alpha" />
        <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.999-cibuild0064469-alpha" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Difflection\Difflection.csproj" />
    </ItemGroup>
</Project>
